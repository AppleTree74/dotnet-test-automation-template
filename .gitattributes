# Normalize line endings. Text files are stored AND checked out with LF on every platform, so
# `dotnet format` (which reads .editorconfig end_of_line = lf) is consistent on Windows and the
# Linux CI runner.
* text=auto eol=lf

# Windows-oriented scripts check out as CRLF (PowerShell 7 handles either; CI runs pwsh fine).
*.ps1 text eol=crlf
*.psm1 text eol=crlf
*.cmd text eol=crlf
*.bat text eol=crlf

# Cross-platform text stays LF on checkout.
*.sh text eol=lf

# Treat generated lock files as text but keep diffs quiet.
package-lock.json text -diff
*.lock.json text -diff

# Binary assets are never line-ending normalized.
*.png binary
*.jpg binary
*.gif binary
*.ico binary
*.zip binary
*.webm binary
*.trx binary

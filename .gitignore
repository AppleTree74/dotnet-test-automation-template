/tests/**/.playwright/
ms-playwright/

# Node
node_modules/
npm-debug.log*

# Local secrets — never commit
appsettings.*.local.json
*.local.env
.env

# IDE / OS
.vs/
.idea/
.vscode/*
!.vscode/extensions.json
*.swp
.DS_Store
Thumbs.db

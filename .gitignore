# Build output
bin/
obj/
[Dd]ebug/
[Rr]elease/
# Runtime artifacts output — anchored to the repo root so it never matches source
# folders such as src/Automation.Core/Artifacts/ (Git ignore matching is case-insensitive
# on Windows/macOS).
/artifacts/
*.user

# .NET
*.dll
*.pdb
project.lock.json
# Keep committed NuGet lock files (locked-mode restore).
!packages.lock.json

# Test / reporting output (top-level, anchored to the repo root)
/allure-results/
/allure-results-sanitized/
/allure-report/
/allure-history/
TestResults/
*.trx
coverage*.xml
coverage*.json

# Playwright
/tests/**/playwright-report/
/tests/**/.playwright/
ms-playwright/

# Node
node_modules/
npm-debug.log*

# Local secrets — never commit
appsettings.local.json
appsettings.*.local.json
*.local.env
.env

# IDE / OS
.vs/
.idea/
.vscode/*
!.vscode/extensions.json
*.swp
.DS_Store
Thumbs.db

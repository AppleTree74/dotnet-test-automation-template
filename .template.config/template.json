{
  "$schema": "http://json.schemastore.org/template",
  "author": "Your Organization",
  "classifications": ["Test", "Automation", "Playwright", "NUnit", "Allure"],
  "identity": "DotNet.TestAutomation.Template",
  "name": "Reusable .NET Test Automation Template",
  "shortName": "test-automation",
  "sourceName": "AutomationTemplate",
  "preferNameDirectory": true,
  "tags": {
    "language": "C#",
    "type": "solution"
  },
  "symbols": {
    "reportName": {
      "type": "parameter",
      "datatype": "string",
      "defaultValue": "Automation Template",
      "replaces": "Automation Template",
      "description": "Display name used in the Allure report."
    }
  },
  "sources": [
    {
      "modifiers": [
        {
          "exclude": [
            "**/bin/**",
            "**/obj/**",
            "artifacts/**",
            "allure-results/**",
            "allure-report/**",
            "allure-history/**",
            "node_modules/**",
            ".git/**",
            ".vs/**"
          ]
        }
      ]
    }
  ]
}
